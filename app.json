{
  "expo": {
    "name": "Tarbiyah",
    "slug": "tarbiyah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3D2F"
    },
    "scheme": "com.tarbiyah.parenting",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tarbiyah.parenting",
      "usesAppleSignIn": true,
      "buildNumber": "4",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.tarbiyah.parenting"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B3D2F",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "d235498c-ead8-4f52-9866-448606bea4f3"
      }
    }
  }
}
